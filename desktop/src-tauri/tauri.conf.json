{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Switchman",
  "version": "0.1.0",
  "identifier": "dev.switchman.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Switchman",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 620,
        "visible": false,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
