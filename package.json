  "type": "module",
  "main": "src/index.js",
  "bin": {
    "switchman": "bin/switchman.js",
    "switchman-mcp": "src/mcp/server.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "CHANGELOG.md",
    "CLAUDE.md",
    "examples/README.md",
    "examples/demo.sh",
    "examples/setup.sh",
    "examples/teardown.sh",
    "examples/walkthrough.sh",
    "examples/taskapi/package.json",
    "examples/taskapi/src/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/switchman-dev/switchman.git"
  },
  "homepage": "https://switchman.dev/",
  "bugs": {
    "url": "https://github.com/switchman-dev/switchman/issues"
  },
  "keywords": [
  "ai-agents",
  "multi-agent",
  "agent-coordination",
  "agentic",
  "claude-code",
  "cursor",
  "codex",
  "openai-codex",
  "windsurf",
  "aider",
  "cline",
  "mcp",
  "model-context-protocol",
  "parallel-agents",
  "parallel-development",
  "worktrees",
  "git-worktree",
  "merge-queue",
  "task-queue",
  "file-locking",
  "ai-coding",
  "developer-tools",
  "llm",
  "merge-confidence",
  "vibe-coding"
],
  "scripts": {
    "start": "node src/cli/index.js",
    "mcp": "node src/mcp/server.js",
    "test": "NODE_NO_WARNINGS=1 node tests/test.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.3.0",
